<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Background when switch is ON/checked -->
    <item android:state_checked="true">
        <shape android:shape="rectangle">
            <solid android:color="#4CAF50"/> <!-- Green for ON -->
            <corners android:radius="8dp"/>
        </shape>
    </item>

    <!-- Background when switch is OFF/unchecked -->
    <item>
        <shape android:shape="rectangle">
            <solid android:color="#E0E0E0"/> <!-- Gray for OFF -->
            <corners android:radius="8dp"/>
        </shape>
    </item>
</selector>