<?xml version="1.0" encoding="utf-8"?>
<androidx.drawerlayout.widget.DrawerLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/drawer_layout"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fitsSystemWindows="true"
    tools:context=".MapMeasurementActivity">

    <!-- Main Content -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/main_content"
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <fragment
            android:id="@+id/map"
            android:name="com.google.android.gms.maps.SupportMapFragment"
            android:layout_width="0dp"
            android:layout_height="0dp"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <!-- Info Panel -->
        <LinearLayout
            android:id="@+id/infoPanel"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:background="#88000000"
            android:orientation="vertical"
            android:padding="8dp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent">

            <TextView
                android:id="@+id/tvLatitude"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/latitude"
                android:textColor="#FFFFFF" />

            <TextView
                android:id="@+id/tvLongitude"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/longitude"
                android:textColor="#FFFFFF" />

            <TextView
                android:id="@+id/tvDistance"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/distance_0_m"
                android:textColor="#FFFFFF" />

            <TextView
                android:id="@+id/tvArea"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/area_0_m"
                android:textColor="#FFFFFF" />

            <TextView
                android:id="@+id/tvGpsStatus"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/gps_searching" />

        </LinearLayout>

        <!-- Lock Button and Mode Toggles -->
        <Button
            android:id="@+id/btnLockMarker"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="8dp"
            android:layout_marginTop="8dp"
            android:layout_marginEnd="4dp"
            android:ellipsize="end"
            android:maxLines="1"
            android:minWidth="0dp"
            android:minHeight="48dp"
            android:padding="6dp"
            android:text="GPS Lock"
            android:textSize="11sp"
            app:layout_constraintEnd_toStartOf="@id/btnToggleMapType"
            app:layout_constraintHorizontal_chainStyle="spread"
            app:layout_constraintHorizontal_weight="1"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/infoPanel" />

        <Button
            android:id="@+id/btnToggleMapType"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="4dp"
            android:layout_marginTop="8dp"
            android:layout_marginEnd="4dp"
            android:backgroundTint="#88000000"
            android:ellipsize="end"
            android:gravity="center"
            android:maxLines="1"
            android:minWidth="0dp"
            android:minHeight="48dp"
            android:padding="6dp"
            android:text="Map: GPS"
            android:textSize="11sp"
            app:layout_constraintEnd_toStartOf="@id/btnToggleMode"
            app:layout_constraintHorizontal_weight="1"
            app:layout_constraintStart_toEndOf="@id/btnLockMarker"
            app:layout_constraintTop_toBottomOf="@id/infoPanel" />

        <Button
            android:id="@+id/btnToggleMode"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="4dp"
            android:layout_marginTop="8dp"
            android:layout_marginEnd="8dp"
            android:backgroundTint="#88000000"
            android:ellipsize="end"
            android:gravity="center"
            android:maxLines="1"
            android:minWidth="0dp"
            android:minHeight="48dp"
            android:padding="6dp"
            android:text="Mode: GPS"
            android:textSize="11sp"
            app:layout_constraintEnd_toStartOf="@+id/spinnerUnits"
            app:layout_constraintHorizontal_weight="1"
            app:layout_constraintStart_toEndOf="@id/btnToggleMapType"
            app:layout_constraintTop_toBottomOf="@id/infoPanel" />

        <Spinner
            android:id="@+id/spinnerUnits"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_margin="8dp"
            android:background="@android:drawable/btn_dropdown"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toBottomOf="@id/infoPanel" />

        <!-- Sensor Info Row -->
        <LinearLayout
            android:id="@+id/sensorInfoPanel"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="8dp"
            android:layout_marginTop="8dp"
            android:layout_marginEnd="8dp"
            android:background="#88000000"
            android:gravity="center"
            android:orientation="horizontal"
            android:padding="8dp"
            android:weightSum="3"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/btnLockMarker">

            <TextView
                android:id="@+id/tvBearing"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:ellipsize="end"
                android:gravity="center"
                android:maxLines="1"
                android:minWidth="80dp"
                android:padding="4dp"
                android:text="Bearing: --°"
                android:textColor="#FFFFFF"
                android:textSize="13sp" />

            <TextView
                android:id="@+id/tvSatellites"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:ellipsize="end"
                android:gravity="center"
                android:maxLines="1"
                android:minWidth="80dp"
                android:padding="4dp"
                android:text="Satellites: --"
                android:textColor="#FFFFFF"
                android:textSize="13sp" />

            <TextView
                android:id="@+id/tvAccuracy"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:ellipsize="end"
                android:gravity="center"
                android:maxLines="1"
                android:minWidth="80dp"
                android:padding="4dp"
                android:text="Accuracy: --m"
                android:textColor="#FFFFFF"
                android:textSize="13sp" />
        </LinearLayout>

        <!-- Bottom Control Panel -->
        <LinearLayout
            android:id="@+id/controlPanel"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:background="#CCFFFFFF"
            android:orientation="horizontal"
            android:padding="8dp"
            android:weightSum="4"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent">

            <Button
                android:id="@+id/btnAddPoint"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginEnd="4dp"
                android:layout_weight="1"
                android:ellipsize="end"
                android:maxLines="1"
                android:minWidth="0dp"
                android:paddingStart="4dp"
                android:paddingEnd="4dp"
                android:text="@string/add_point"
                android:textSize="12sp" />

            <Button
                android:id="@+id/btnUndoPoint"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginEnd="4dp"
                android:layout_weight="1"
                android:ellipsize="end"
                android:maxLines="1"
                android:minWidth="0dp"
                android:paddingStart="4dp"
                android:paddingEnd="4dp"
                android:text="@string/undo"
                android:textSize="12sp" />

            <Button
                android:id="@+id/btnClearMap"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginEnd="4dp"
                android:layout_weight="1"
                android:ellipsize="end"
                android:maxLines="1"
                android:minWidth="0dp"
                android:paddingStart="4dp"
                android:paddingEnd="4dp"
                android:text="@string/clear"
                android:textSize="12sp" />

            <Button
                android:id="@+id/btnSavePlot"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:ellipsize="end"
                android:maxLines="1"
                android:minWidth="0dp"
                android:paddingStart="4dp"
                android:paddingEnd="4dp"
                android:text="@string/save"
                android:textSize="12sp" />
        </LinearLayout>

        <ProgressBar
            android:id="@+id/progressGps"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:visibility="gone"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <!-- Hamburger Icon Button -->
        <ImageButton
            android:id="@+id/btnMenu"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:layout_margin="16dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:src="@drawable/ic_menu"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            android:contentDescription="Open Menu" />

    </androidx.constraintlayout.widget.ConstraintLayout>

    <!-- Navigation Drawer -->
    <com.google.android.material.navigation.NavigationView
        android:id="@+id/nav_view"
        android:layout_width="wrap_content"
        android:layout_height="match_parent"
        android:layout_gravity="start"
        app:headerLayout="@layout/nav_header"
        app:menu="@menu/drawer_menu" />

</androidx.drawerlayout.widget.DrawerLayout>