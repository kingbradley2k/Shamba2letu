<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".MapMeasurementActivity">

    <!-- Info Panel -->


    <fragment
        android:id="@+id/map"
        android:name="com.google.android.gms.maps.SupportMapFragment"
        android:layout_width="0dp"
        android:layout_height="0dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="1.0"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintVertical_bias="1.0" />

    <LinearLayout
        android:id="@+id/infoPanel"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:background="#88000000"
        android:orientation="vertical"
        android:padding="8dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <TextView
            android:id="@+id/tvLatitude"
            android:layout_width="wrap_content"
            android:textColor="#FFFFFF"
            android:layout_height="wrap_content"
            android:text="@string/latitude" />

        <TextView
            android:id="@+id/tvLongitude"
            android:layout_width="wrap_content"
            android:textColor="#FFFFFF"
            android:layout_height="wrap_content"
            android:text="@string/longitude" />

        <TextView
            android:id="@+id/tvDistance"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="#FFFFFF"
            android:text="@string/distance_0_m" />

        <TextView
            android:id="@+id/tvArea"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="#FFFFFF"
            android:text="@string/area_0_m" />

        <TextView
            android:id="@+id/tvGpsStatus"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/gps_searching" />

    </LinearLayout>

    <!-- Lock Button - Positioned below infoPanel -->
    <Button
        android:id="@+id/btnLockMarker"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="GPS Lock"
        android:textSize="11sp"
        android:padding="6dp"
        android:maxLines="1"
        android:ellipsize="end"
        android:minWidth="0dp"
        android:minHeight="48dp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toStartOf="@id/btnToggleMapType"
        app:layout_constraintTop_toBottomOf="@id/infoPanel"
        app:layout_constraintHorizontal_chainStyle="spread"
        app:layout_constraintHorizontal_weight="1"
        android:layout_marginStart="8dp"
        android:layout_marginTop="8dp"
        android:layout_marginEnd="4dp" />

    <!-- Toggle between Maps -->
    <Button
        android:id="@+id/btnToggleMapType"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:backgroundTint="#88000000"
        android:gravity="center"
        android:text="Map: GPS"
        android:textSize="11sp"
        android:padding="6dp"
        android:maxLines="1"
        android:ellipsize="end"
        android:minWidth="0dp"
        android:minHeight="48dp"
        app:layout_constraintStart_toEndOf="@id/btnLockMarker"
        app:layout_constraintEnd_toStartOf="@id/btnToggleMode"
        app:layout_constraintTop_toBottomOf="@id/infoPanel"
        app:layout_constraintHorizontal_weight="1"
        android:layout_marginTop="8dp"
        android:layout_marginStart="4dp"
        android:layout_marginEnd="4dp" />

    <!-- Sensor Info Row -->
    <Button
        android:id="@+id/btnToggleMode"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:backgroundTint="#88000000"
        android:gravity="center"
        android:text="Mode: GPS"
        android:textSize="11sp"
        android:padding="6dp"
        android:maxLines="1"
        android:ellipsize="end"
        android:minWidth="0dp"
        android:minHeight="48dp"
        app:layout_constraintStart_toEndOf="@id/btnToggleMapType"
        app:layout_constraintEnd_toStartOf="@+id/spinnerUnits"
        app:layout_constraintTop_toBottomOf="@id/infoPanel"
        app:layout_constraintHorizontal_weight="1"
        android:layout_marginTop="8dp"
        android:layout_marginStart="4dp"
        android:layout_marginEnd="8dp" />

    <LinearLayout
        android:id="@+id/sensorInfoPanel"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:background="#88000000"
        android:padding="8dp"
        android:gravity="center"
        android:weightSum="3"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toBottomOf="@id/btnLockMarker"
        android:layout_marginTop="8dp"
        android:layout_marginStart="8dp"
        android:layout_marginEnd="8dp">

        <TextView
            android:id="@+id/tvBearing"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Bearing: --°"
            android:textSize="13sp"
            android:textColor="#FFFFFF"
            android:gravity="center"
            android:padding="4dp"
            android:maxLines="1"
            android:ellipsize="end"
            android:minWidth="80dp" />

        <TextView
            android:id="@+id/tvSatellites"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Satellites: --"
            android:textSize="13sp"
            android:textColor="#FFFFFF"
            android:gravity="center"
            android:padding="4dp"
            android:maxLines="1"
            android:ellipsize="end"
            android:minWidth="80dp" />

        <TextView
            android:id="@+id/tvAccuracy"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Accuracy: --m"
            android:textSize="13sp"
            android:textColor="#FFFFFF"
            android:gravity="center"
            android:padding="4dp"
            android:maxLines="1"
            android:ellipsize="end"
            android:minWidth="80dp" />
    </LinearLayout>


    <!-- Unit Spinner -->
    <Spinner
        android:id="@+id/spinnerUnits"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:background="@android:drawable/btn_dropdown"
        android:layout_margin="8dp"
        app:layout_constraintTop_toBottomOf="@id/infoPanel"
        app:layout_constraintEnd_toEndOf="parent" />

<!--    <Switch-->
<!--        android:id="@+id/LockGprs"-->
<!--        android:layout_width="150dp"-->
<!--        android:layout_height="46dp"-->
<!--        android:layout_marginLeft="18dp"-->
<!--        android:layout_marginTop="8dp"-->
<!--        android:padding="4dp"-->
<!--        android:text="GPSLock"-->
<!--        android:textSize="24sp"-->
<!--        app:layout_constraintStart_toStartOf="@id/infoPanel"-->
<!--        app:layout_constraintTop_toBottomOf="@id/infoPanel"-->
<!--        tools:layout_constraintLeft_toLeftOf="@id/infoPanel"-->
<!--        tools:layout_constraintTop_toBottomOf="@id/infoPanel" />-->

    <!-- Bottom Control Panel -->
    <LinearLayout
        android:id="@+id/controlPanel"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:background="#CCFFFFFF"
        android:padding="8dp"
        android:weightSum="4"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <Button
            android:id="@+id/btnAddPoint"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="@string/add_point"
            android:maxLines="1"
            android:ellipsize="end"
            android:textSize="12sp"
            android:paddingStart="4dp"
            android:paddingEnd="4dp"
            android:minWidth="0dp"
            android:layout_marginEnd="4dp" />

        <Button
            android:id="@+id/btnUndoPoint"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="@string/undo"
            android:maxLines="1"
            android:ellipsize="end"
            android:textSize="12sp"
            android:paddingStart="4dp"
            android:paddingEnd="4dp"
            android:minWidth="0dp"
            android:layout_marginEnd="4dp" />

        <Button
            android:id="@+id/btnClearMap"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="@string/clear"
            android:maxLines="1"
            android:ellipsize="end"
            android:textSize="12sp"
            android:paddingStart="4dp"
            android:paddingEnd="4dp"
            android:minWidth="0dp"
            android:layout_marginEnd="4dp" />

        <Button
            android:id="@+id/btnSavePlot"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="@string/save"
            android:maxLines="1"
            android:ellipsize="end"
            android:textSize="12sp"
            android:paddingStart="4dp"
            android:paddingEnd="4dp"
            android:minWidth="0dp" />
    </LinearLayout>
    <!-- GPS Loading Indicator -->
    <ProgressBar
        android:id="@+id/progressGps"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:visibility="gone"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />


</androidx.constraintlayout.widget.ConstraintLayout>
